---
import salesSrc from '../assets/Siite-Sales.webp?url';
---

<section class="contact-section">
  <div class="contact-card">
    <div class="contact-bg" aria-hidden="true">
      <div class="contact-blob"></div>
    </div>

    <div class="contact-content">
      <span class="contact-label">Lad os tage en snak</span>
      <h2>Skal vi tage en<br>uforpligtende snak?</h2>
      <p>Du behøver ikke have en færdig kravspecifikation klar for at tale med os. Vores erhvervsrådgiver, Christian, står klar til at hjælpe dig videre.</p>

      <div class="contact-actions">
        <a href="/kontakt" class="btn-solid">Få et uforpligtende tilbud <i class="fa-solid fa-arrow-right"></i></a>
        <a href="tel:25818106" class="btn-ghost"><i class="fa-solid fa-phone"></i> 25 81 81 06</a>
      </div>
    </div>

    <div class="contact-image">
      <img src={salesSrc} alt="Christian – erhvervsrådgiver hos Siite" loading="lazy" decoding="async" />
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: #ffffff;
    padding: 40px clamp(20px, 4vw, 48px) 120px;
  }

  .contact-card {
    position: relative;
    display: flex;
    align-items: stretch;
    background: #1a1a1a;
    border-radius: 32px;
    overflow: hidden;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    min-height: 420px;
  }

  /* Dekorativ orange glød */
  .contact-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .contact-blob {
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240, 90, 36, 0.32) 0%, transparent 68%);
    filter: blur(20px);
    right: 22%;
    bottom: -180px;
  }

  .contact-content {
    flex: 0 0 56%;
    padding: 72px 48px 72px 72px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .contact-label {
    display: block;
    font-family: 'Comfortaa', cursive;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: #f05a24;
    margin-bottom: 20px;
  }

  .contact-content h2 {
    font-family: 'Comfortaa', cursive;
    font-size: clamp(1.9rem, 3.2vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.14;
    margin-bottom: 22px;
  }

  .contact-content p {
    font-family: 'Comfortaa', cursive;
    font-size: 0.98rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
    max-width: 460px;
    margin-bottom: 36px;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .btn-solid {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 14px 28px;
    background: #f05a24;
    color: #fff;
    border-radius: 999px;
    font-family: 'Comfortaa', cursive;
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(240, 90, 36, 0.35);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-solid:hover {
    background: #d44e1c;
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(240, 90, 36, 0.42);
  }

  .btn-solid i {
    transition: transform 0.2s ease;
  }

  .btn-solid:hover i {
    transform: translateX(3px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 14px 26px;
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    font-family: 'Comfortaa', cursive;
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .btn-ghost i {
    color: #f05a24;
    font-size: 0.82rem;
  }

  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.05);
  }

  .contact-image {
    flex: 0 0 44%;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .contact-image img {
    width: 92%;
    max-height: 460px;
    object-fit: contain;
    object-position: bottom center;
    display: block;
  }

  @media (max-width: 860px) {
    .contact-card {
      flex-direction: column;
      min-height: auto;
    }

    .contact-content {
      flex: none;
      padding: 48px 32px 28px;
      order: 2;
    }

    .contact-image {
      flex: none;
      order: 1;
      height: 280px;
    }

    .contact-image img {
      max-height: 280px;
    }

    .contact-blob {
      right: 50%;
      transform: translateX(50%);
      bottom: auto;
      top: -200px;
    }
  }

  @media (max-width: 480px) {
    .contact-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-solid,
    .btn-ghost {
      justify-content: center;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initContactCTA() {
    const section = document.querySelector(".contact-section");
    if (!section) return; // Findes kun på forsiden
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.from(".contact-content > *", {
      y: 30,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
      stagger: 0.1,
      scrollTrigger: { trigger: ".contact-card", start: "top 78%", once: true },
    });

    gsap.from(".contact-image img", {
      y: 40,
      opacity: 0,
      duration: 0.9,
      ease: "power3.out",
      scrollTrigger: { trigger: ".contact-card", start: "top 78%", once: true },
    });
  }

  document.addEventListener("astro:page-load", initContactCTA);
</script>

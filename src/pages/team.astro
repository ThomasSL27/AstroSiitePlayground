---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import TheNav from '../components/TheNav.astro';
import TheFooter from '../components/TheFooter.astro';
import heroImg from '../assets/1779109002530.jpeg';

// Alle teambilleder hentes og optimeres af Astro
const photos = import.meta.glob<ImageMetadata>(
  '../assets/team/*.{jpg,jpeg,png}',
  { eager: true, import: 'default' }
);
const photoFor = (file: string) => photos[`../assets/team/${file}`];

const categories = [
  { id: 'alle', label: 'Alle' },
  { id: 'ledelse', label: 'Ledelse' },
  { id: 'salg', label: 'Salg & Account' },
  { id: 'outbound', label: 'Outbound' },
  { id: 'udvikling', label: 'Udvikling' },
  { id: 'marketing', label: 'Marketing' },
  { id: 'backoffice', label: 'Backoffice' },
];

// Kort badge-label pr. kategori
const catLabel: Record<string, string> = {
  ledelse: 'Ledelse',
  salg: 'Salg',
  outbound: 'Outbound',
  udvikling: 'Udvikling',
  marketing: 'Marketing',
  backoffice: 'Backoffice',
};

type Member = {
  name: string;
  title: string;
  cat: string;
  img: string;
  email: string;
  phone?: string;
  linkedin: string;
};

const team: Member[] = [
  // Ledelse & partnere
  { name: 'Mike Vestergaard', title: 'CEO, Partner', cat: 'ledelse', img: 'mike.jpg', email: 'mike@siite.dk', linkedin: 'https://www.linkedin.com/in/mikevestergaard/' },
  { name: 'Mikkel Kragelund', title: 'COO, Partner', cat: 'ledelse', img: 'mikkel-kragelund.jpg', email: 'mikkel@siite.dk', phone: '61 10 81 03', linkedin: 'https://www.linkedin.com/in/mikkel-kragelund-7b8088151/' },
  { name: 'Mads Klokkerholm Nielsen', title: 'CCO, Partner', cat: 'ledelse', img: 'mads-klokkerholm.jpg', email: 'mads@siite.dk', linkedin: 'https://www.linkedin.com/in/madsklokkerholm/' },
  { name: 'Leonardo Miodrag', title: 'CMO, Partner', cat: 'ledelse', img: 'leonardo.jpg', email: 'leonardo@siite.dk', linkedin: 'https://www.linkedin.com/in/leonardomiodrag/' },
  { name: 'Christian Barnbæk', title: 'Client Director', cat: 'ledelse', img: 'christian-barnbaek.jpg', email: 'christian.b@siite.dk', linkedin: 'https://www.linkedin.com/in/christian-barnbæk-jensen-3842271a1/' },
  { name: 'Luna Bock', title: 'CLO', cat: 'ledelse', img: 'luna.jpg', email: 'luna@siite.dk', linkedin: 'https://www.linkedin.com/in/luna-marie-søgaard-bock/' },

  // Salg & Account
  { name: 'Mathias Nyborg Nielsen', title: 'Key Account Director', cat: 'salg', img: 'mathias.jpg', email: 'mathias@siite.dk', phone: '22 65 81 04', linkedin: 'https://www.linkedin.com/in/mathias-nyborg-nielsen-01468a224/' },
  { name: 'Kenneth Vinther Kristensen', title: 'Key Account Manager', cat: 'salg', img: 'kenneth.jpg', email: 'kenneth@siite.dk', phone: '22 16 81 02', linkedin: 'https://www.linkedin.com/in/kenneth-vinther-kristensen-101817145/' },
  { name: 'Kasper Daniel Jørgensen', title: 'Head of Sales New Business, CPH', cat: 'salg', img: 'kasper-daniel.png', email: 'kasper@siite.dk', phone: '53 57 20 74', linkedin: 'https://www.linkedin.com/in/kasper-daniel-629850234/' },
  { name: 'Martin Vanggaard Sund', title: 'Account Manager', cat: 'salg', img: 'martin.jpg', email: 'martin@siite.dk', phone: '22 90 81 04', linkedin: 'https://www.linkedin.com/in/martinandersensund/' },
  { name: 'Mads Christensen', title: 'Account Manager', cat: 'salg', img: 'mads-christensen.jpg', email: 'mads.c@siite.dk', phone: '61 10 81 02', linkedin: 'https://www.linkedin.com/in/mads-christensen-1b408a1a4/' },
  { name: 'Conor Demontli', title: 'Account Manager', cat: 'salg', img: 'conor.jpg', email: 'conor@siite.dk', phone: '25 37 81 05', linkedin: 'https://www.linkedin.com/in/conor-demontli-18041b371/' },
  { name: 'Oscar Broen', title: 'Account Manager', cat: 'salg', img: 'oscar.jpg', email: 'oscar@siite.dk', phone: '22 66 81 95', linkedin: 'https://www.linkedin.com/in/oscar-broen-135101255/' },
  { name: 'Dan Richard Pedersen', title: 'Account Manager', cat: 'salg', img: 'dan.jpg', email: 'dan@siite.dk', phone: '22 66 81 45', linkedin: 'https://www.linkedin.com/in/dan-richard-pedersen-90b691187/' },
  { name: 'Victoria Kjær Kruse', title: 'Account Manager', cat: 'salg', img: 'victoria.png', email: 'victoria@siite.dk', phone: '53 58 76 17', linkedin: 'https://www.linkedin.com/in/victoria-kruse-304215196/' },

  // Outbound
  { name: 'Christian Thorvald Johansen', title: 'Outbound, Team Lead', cat: 'outbound', img: 'christian-thorvald.jpg', email: 'christian@siite.dk', phone: '22 27 81 06', linkedin: 'https://www.linkedin.com/in/christian-johansen-0b5349309/' },
  { name: 'Nicklas Morén', title: 'Outbound', cat: 'outbound', img: 'nicklas-moren.jpg', email: 'nicklas@siite.dk', phone: '25 33 81 04', linkedin: 'https://www.linkedin.com/in/nicklas-moren/' },
  { name: 'Amel Spahic', title: 'Outbound', cat: 'outbound', img: 'amel.jpg', email: 'amel@siite.dk', phone: '22 66 81 43', linkedin: 'https://www.linkedin.com/in/amel-spahic-826795170/' },

  // Udvikling
  { name: 'Elvir Sejfulai', title: 'Web Developer', cat: 'udvikling', img: 'elvir.jpg', email: 'elvir@siite.dk', phone: '42 91 29 35', linkedin: 'https://www.linkedin.com/in/elvir-sejfulai/' },
  { name: 'Mads Buhl', title: 'Junior Web Developer', cat: 'udvikling', img: 'mads-buhl.jpg', email: 'mads.b@siite.dk', linkedin: 'https://www.linkedin.com/in/mads-venø-buhl-134bbb266/' },
  { name: 'Thomas Søhus Larsen', title: 'Junior Web Developer', cat: 'udvikling', img: 'thomas.jpg', email: 'thomas@siite.dk', linkedin: 'https://dk.linkedin.com/in/thomas-søhus-larsen-37a48b362' },

  // Marketing
  { name: 'Mikkel Friis', title: 'Marketing Manager', cat: 'marketing', img: 'mikkel-friis.jpg', email: 'mikkel@siite.dk', linkedin: 'https://www.linkedin.com/in/mikkel-friis-30a9b4274/' },
  { name: 'Nicklas Dyrmose', title: 'SEO Specialist', cat: 'marketing', img: 'nicklas-dyrmose.jpg', email: 'nicklas.d@siite.dk', linkedin: 'https://www.linkedin.com/in/nicklas-dyrmose/' },
  { name: 'Kasper Glerup Rasmussen', title: 'Marketing Assistant', cat: 'marketing', img: 'kasper-glerup.jpg', email: 'kasper@siite.dk', linkedin: 'https://www.linkedin.com/in/kasper-glerup-rasmussen/' },
  { name: 'Natascha Leal', title: 'Marketing Assistant', cat: 'marketing', img: 'natascha.jpg', email: 'natascha@siite.dk', linkedin: 'https://www.linkedin.com/in/natascha-leal/' },
  { name: 'Casper Thusgaard', title: 'Marketing Assistant', cat: 'marketing', img: 'casper.jpg', email: 'casper@siite.dk', linkedin: 'https://www.linkedin.com/in/casper-thusgaard-2a748556/' },
  { name: 'Tobias William Christensen', title: 'Content Creator', cat: 'marketing', img: 'tobias.jpg', email: 'tobias@siite.dk', linkedin: 'https://www.linkedin.com/in/tobias-christensen-b1bbab2a9/' },

  // Backoffice
  { name: 'Sofie Krogh Sand', title: 'Lead, Backoffice', cat: 'backoffice', img: 'sofie.jpg', email: 'sofie@siite.dk', linkedin: 'https://www.linkedin.com/in/sofie-krogh-sand-461195118/' },
];

const teamCount = team.length;
const teamDepartments = categories.length - 1;
---

<Layout title="Team — Siite">
  <TheNav revealOnScroll={false} />

  <main>
    <!-- ─── Hero ─── -->
    <section class="team-hero">
      <div class="hero-media">
        <Image
          src={heroImg}
          alt="Holdet bag Siite samlet foran kontoret"
          width={1200}
          height={800}
          sizes="(max-width: 900px) 92vw, 60vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div class="hero-content">
        <span class="hero-eyebrow">Mød holdet bag din digitale vækst</span>
        <h1 class="hero-title">Mennesker der<br />driver resultater</h1>
        <p class="hero-intro">
          Hos Siite er vi ikke bare en samling freelancere. Vi er et sammentømret
          hold af eksperter, der hver især brænder for vores felt.
        </p>

        <div class="hero-stats">
          <div class="stat">
            <strong class="stat-val" data-count={teamCount}>0</strong>
            <span class="stat-label">Specialister</span>
          </div>
          <span class="stat-divider"></span>
          <div class="stat">
            <strong class="stat-val" data-count={teamDepartments}>0</strong>
            <span class="stat-label">Afdelinger</span>
          </div>
          <span class="stat-divider"></span>
          <div class="stat">
            <strong class="stat-val">1</strong>
            <span class="stat-label">Fælles mission</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Filter ─── -->
    <div class="filter-bar" role="tablist" aria-label="Filtrér holdet">
      {
        categories.map((c, i) => (
          <button
            class:list={['filter-pill', { 'is-active': i === 0 }]}
            data-cat={c.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {c.label}
          </button>
        ))
      }
    </div>

    <!-- ─── Grid ─── -->
    <section class="team-wrap">
      <div class="team-grid">
        {
          team.map((m) => {
            const src = photoFor(m.img);
            return (
              <article class="team-card" data-cat={m.cat}>
                <div class="card-photo">
                  {src && (
                    <Image src={src} alt={m.name} width={440} height={440} />
                  )}
                  <span class="card-cat">{catLabel[m.cat]}</span>
                </div>
                <div class="card-meta">
                  <h3>{m.name}</h3>
                  <p>{m.title}</p>

                  <div class="card-contact">
                    <a
                      class="contact-link"
                      href={`mailto:${m.email}`}
                      aria-label={`Send mail til ${m.name}`}
                      title={m.email}
                    >
                      <i class="fa-solid fa-envelope"></i>
                    </a>
                    {m.phone && (
                      <a
                        class="contact-link"
                        href={`tel:+45${m.phone.replace(/\s/g, '')}`}
                        aria-label={`Ring til ${m.name}`}
                        title={`+45 ${m.phone}`}
                      >
                        <i class="fa-solid fa-phone"></i>
                      </a>
                    )}
                    <a
                      class="contact-link"
                      href={m.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${m.name} på LinkedIn`}
                      title="LinkedIn"
                    >
                      <i class="fa-brands fa-linkedin-in"></i>
                    </a>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>

      <p class="no-results" hidden>Ingen i denne afdeling endnu.</p>
    </section>
  </main>
  <TheFooter />
</Layout>

<style>
  main {
    background: #ffffff;
  }

  /* ─── Hero ─── */
  .team-hero {
    position: relative;
    display: grid;
    grid-template-columns: 3fr 2fr;
    align-items: center;
    gap: clamp(32px, 5vw, 64px);
    padding: clamp(120px, 15vh, 170px) clamp(20px, 4vw, 48px) 64px;
    max-width: 1600px;
    margin: 0 auto;
  }

  .team-hero::before {
    content: '';
    position: absolute;
    top: 8%;
    right: -80px;
    width: 420px;
    max-width: 60vw;
    height: 420px;
    background: radial-gradient(circle, rgba(240, 90, 36, 0.14), transparent 68%);
    pointer-events: none;
    z-index: -1;
  }

  .hero-media {
    position: relative;
  }

  .hero-media :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 32px;
    display: block;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.12);
  }

  .hero-content {
    text-align: left;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: #f05a24;
    margin-bottom: 22px;
    padding: 7px 18px;
    border: 1.5px solid #f9ddd2;
    border-radius: 999px;
    background: #fff7f3;
  }

  .hero-title {
    font-size: clamp(2.1rem, 3.4vw, 3.4rem);
    font-weight: 700;
    line-height: 1.12;
    color: #1a1a1a;
    letter-spacing: 0.01em;
  }

  .hero-intro {
    margin: 22px 0 0;
    max-width: 460px;
    font-size: 1rem;
    line-height: 1.8;
    color: #777;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(18px, 2.5vw, 36px);
    margin-top: 40px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }

  .stat-val {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #f05a24;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b6b6b;
    font-weight: 600;
  }

  .stat-divider {
    width: 1px;
    height: 38px;
    background: #eee;
  }

  /* ─── Filter ─── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding: 8px clamp(20px, 4vw, 48px) 0;
    max-width: 920px;
    margin: 0 auto 40px;
  }

  .filter-pill {
    font-family: 'Comfortaa', cursive;
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
    background: #f4f4f4;
    border: 1.5px solid transparent;
    padding: 9px 18px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }

  .filter-pill:hover {
    color: #f05a24;
    background: #fff3ee;
  }

  .filter-pill.is-active {
    background: #f05a24;
    color: #fff;
    border-color: #f05a24;
  }

  .filter-pill:active {
    transform: scale(0.96);
  }

  /* ─── Grid ─── */
  .team-wrap {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px) 120px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px;
  }

  .team-card {
    position: relative;
    background: #fbfbfb;
    border: 1px solid #efefef;
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.32s ease, box-shadow 0.32s ease, border-color 0.32s ease;
    will-change: transform;
  }

  .team-card::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 4px;
    width: 100%;
    background: #f05a24;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 60px rgba(240, 90, 36, 0.16);
    border-color: #f9ddd2;
  }

  .team-card:hover::after {
    transform: scaleX(1);
  }

  .card-photo {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0f0f0;
  }

  .card-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.4s ease;
  }

  .team-card:hover .card-photo :global(img) {
    transform: scale(1.07);
  }

  .card-cat {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: #f05a24;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 5px 11px;
    border-radius: 999px;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .team-card:hover .card-cat {
    opacity: 1;
    transform: translateY(0);
  }

  .card-meta {
    padding: 18px 18px 22px;
  }

  .card-meta h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
    transition: color 0.25s ease;
  }

  .team-card:hover .card-meta h3 {
    color: #f05a24;
  }

  .card-meta p {
    font-size: 0.78rem;
    color: #6e6e6e;
    margin-top: 5px;
    line-height: 1.4;
    min-height: 2.2em;
  }

  .card-contact {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid #f0f0f0;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #fff3ee;
    color: #f05a24;
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .contact-link:hover {
    background: #f05a24;
    color: #fff;
    transform: translateY(-2px);
  }

  .no-results {
    text-align: center;
    color: #999;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  /* ─── Hero stakkes på smalle skærme ─── */
  @media (max-width: 820px) {
    .team-hero {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: left;
    }

    .hero-media {
      order: -1;
    }

    .hero-media :global(img) {
      aspect-ratio: 16 / 10;
      border-radius: 24px;
    }
  }

  /* ─── Mobil ─── */
  @media (max-width: 768px) {
    .team-hero {
      padding-top: 116px;
    }

    .hero-stats {
      gap: 18px;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .card-meta {
      padding: 14px 14px 18px;
    }

    .card-meta h3 {
      font-size: 0.88rem;
    }

    .card-meta p {
      font-size: 0.72rem;
    }

    .filter-bar {
      gap: 8px;
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      padding-bottom: 6px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .filter-bar::-webkit-scrollbar {
      display: none;
    }

    .filter-pill {
      flex: 0 0 auto;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { Flip } from 'gsap/Flip';

  gsap.registerPlugin(ScrollTrigger, Flip);

  function initTeam() {
    const hero = document.querySelector('.team-hero');
    const grid = document.querySelector('.team-grid');
    if (!hero || !grid) return; // Vi er ikke på team-siden

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cards = gsap.utils.toArray<HTMLElement>('.team-card');

    /* ── Tæller-animation ── */
    function runCounters() {
      document.querySelectorAll<HTMLElement>('.stat-val[data-count]').forEach((el) => {
        const target = Number(el.dataset.count || '0');
        if (reduce) {
          el.textContent = String(target);
          return;
        }
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 1.6,
          ease: 'power2.out',
          onUpdate: () => {
            el.textContent = Math.round(obj.val).toString();
          },
        });
      });
    }

    if (!reduce) {
      /* ── Hero entrance ── */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('.hero-media', { x: -44, opacity: 0, duration: 0.9 })
        .from(
          '.hero-content > *',
          { y: 26, opacity: 0, duration: 0.7, stagger: 0.1 },
          '-=0.55'
        );

      /* ── Kort: scroll-reveal med stagger ── */
      gsap.set(cards, { opacity: 0, y: 34 });
      ScrollTrigger.create({
        trigger: '.team-grid',
        start: 'top 85%',
        once: true,
        onEnter: () =>
          gsap.to(cards, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: { each: 0.035, grid: 'auto', from: 'start' },
          }),
      });
    }

    runCounters();

    /* ── Filter ── */
    const pills = gsap.utils.toArray<HTMLElement>('.filter-pill');
    const noResults = document.querySelector<HTMLElement>('.no-results');
    const teamWrap = document.querySelector<HTMLElement>('.team-wrap');
    let isFiltering = false;

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        if (isFiltering) return;
        const cat = pill.dataset.cat || 'alle';

        pills.forEach((p) => {
          const active = p === pill;
          p.classList.toggle('is-active', active);
          p.setAttribute('aria-selected', String(active));
        });

        const toShow = cards.filter((c) => cat === 'alle' || c.dataset.cat === cat);
        const toHide = cards.filter((c) => cat !== 'alle' && c.dataset.cat !== cat);

        if (noResults) noResults.hidden = toShow.length > 0;

        if (reduce) {
          toHide.forEach((c) => { c.style.display = 'none'; });
          toShow.forEach((c) => { c.style.display = ''; gsap.set(c, { opacity: 1, y: 0, scale: 1 }); });
          return;
        }

        isFiltering = true;

        // Lock container height so footer doesn't jump during swap
        if (teamWrap) teamWrap.style.minHeight = teamWrap.offsetHeight + 'px';

        const tl = gsap.timeline({
          onComplete: () => {
            isFiltering = false;
            if (teamWrap) teamWrap.style.minHeight = '';
          },
        });

        // Phase 1: fade out cards leaving
        if (toHide.length > 0) {
          tl.to(toHide, {
            opacity: 0,
            duration: 0.18,
            ease: 'power2.in',
            stagger: 0.01,
          });
        }

        // Phase 2: swap visibility
        tl.add(() => {
          toHide.forEach((c) => { c.style.display = 'none'; });
          toShow.forEach((c) => { c.style.display = ''; gsap.set(c, { opacity: 0 }); });
        });

        // Phase 3: fade in cards entering
        tl.to(toShow, {
          opacity: 1,
          duration: 0.32,
          ease: 'power2.out',
          stagger: { each: 0.028, from: 'start' },
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initTeam);
</script>

---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import TheNav from '../components/TheNav.astro';

// Alle teambilleder hentes og optimeres af Astro
const photos = import.meta.glob<ImageMetadata>(
  '../assets/team/*.{jpg,jpeg,png}',
  { eager: true, import: 'default' }
);
const photoFor = (file: string) => photos[`../assets/team/${file}`];

const categories = [
  { id: 'alle', label: 'Alle' },
  { id: 'ledelse', label: 'Ledelse' },
  { id: 'salg', label: 'Salg & Account' },
  { id: 'outbound', label: 'Outbound' },
  { id: 'udvikling', label: 'Udvikling' },
  { id: 'marketing', label: 'Marketing' },
  { id: 'backoffice', label: 'Backoffice' },
];

// Kort badge-label pr. kategori
const catLabel: Record<string, string> = {
  ledelse: 'Ledelse',
  salg: 'Salg',
  outbound: 'Outbound',
  udvikling: 'Udvikling',
  marketing: 'Marketing',
  backoffice: 'Backoffice',
};

type Member = { name: string; title: string; cat: string; img: string };

const team: Member[] = [
  // Ledelse & partnere
  { name: 'Mike Vestergaard', title: 'CEO, Partner', cat: 'ledelse', img: 'mike.jpg' },
  { name: 'Mikkel Kragelund', title: 'COO, Partner', cat: 'ledelse', img: 'mikkel-kragelund.jpg' },
  { name: 'Mads Klokkerholm Nielsen', title: 'CCO, Partner', cat: 'ledelse', img: 'mads-klokkerholm.jpg' },
  { name: 'Leonardo Miodrag', title: 'CMO, Partner', cat: 'ledelse', img: 'leonardo.jpg' },
  { name: 'Christian Barnbæk', title: 'Client Director', cat: 'ledelse', img: 'christian-barnbaek.jpg' },
  { name: 'Luna Bock', title: 'CLO', cat: 'ledelse', img: 'luna.jpg' },

  // Salg & Account
  { name: 'Mathias Nyborg Nielsen', title: 'Key Account Director', cat: 'salg', img: 'mathias.jpg' },
  { name: 'Kenneth Vinther Kristensen', title: 'Key Account Manager', cat: 'salg', img: 'kenneth.jpg' },
  { name: 'Kasper Daniel Jørgensen', title: 'Head of Sales New Business, CPH', cat: 'salg', img: 'kasper-daniel.png' },
  { name: 'Martin Vanggaard Sund', title: 'Account Manager', cat: 'salg', img: 'martin.jpg' },
  { name: 'Mads Christensen', title: 'Account Manager', cat: 'salg', img: 'mads-christensen.jpg' },
  { name: 'Conor Demontli', title: 'Account Manager', cat: 'salg', img: 'conor.jpg' },
  { name: 'Oscar Broen', title: 'Account Manager', cat: 'salg', img: 'oscar.jpg' },
  { name: 'Dan Richard Pedersen', title: 'Account Manager', cat: 'salg', img: 'dan.jpg' },
  { name: 'Victoria Kjær Kruse', title: 'Account Manager', cat: 'salg', img: 'victoria.png' },

  // Outbound
  { name: 'Christian Thorvald Johansen', title: 'Outbound, Team Lead', cat: 'outbound', img: 'christian-thorvald.jpg' },
  { name: 'Nicklas Morén', title: 'Outbound', cat: 'outbound', img: 'nicklas-moren.jpg' },
  { name: 'Amel Spahic', title: 'Outbound', cat: 'outbound', img: 'amel.jpg' },

  // Udvikling
  { name: 'Elvir Sejfulai', title: 'Web Developer', cat: 'udvikling', img: 'elvir.jpg' },
  { name: 'Mads Buhl', title: 'Junior Web Developer', cat: 'udvikling', img: 'mads-buhl.jpg' },
  { name: 'Thomas Søhus Larsen', title: 'Junior Web Developer', cat: 'udvikling', img: 'thomas.jpg' },

  // Marketing
  { name: 'Mikkel Friis', title: 'Marketing Manager', cat: 'marketing', img: 'mikkel-friis.jpg' },
  { name: 'Nicklas Dyrmose', title: 'SEO Specialist', cat: 'marketing', img: 'nicklas-dyrmose.jpg' },
  { name: 'Kasper Glerup Rasmussen', title: 'Marketing Assistant', cat: 'marketing', img: 'kasper-glerup.jpg' },
  { name: 'Natascha Leal', title: 'Marketing Assistant', cat: 'marketing', img: 'natascha.jpg' },
  { name: 'Casper Thusgaard', title: 'Marketing Assistant', cat: 'marketing', img: 'casper.jpg' },
  { name: 'Tobias William Christensen', title: 'Content Creator', cat: 'marketing', img: 'tobias.jpg' },

  // Backoffice
  { name: 'Sofie Krogh Sand', title: 'Lead, Backoffice', cat: 'backoffice', img: 'sofie.jpg' },
];

const teamCount = team.length;
const teamDepartments = categories.length - 1;
---

<Layout title="Team — Siite">
  <TheNav revealOnScroll={false} />

  <main>
    <!-- ─── Hero ─── -->
    <section class="team-hero">
      <span class="hero-eyebrow">Mød holdet bag din digitale vækst</span>
      <h1 class="hero-title">Mennesker der<br />driver resultater</h1>
      <p class="hero-intro">
        Hos Siite er vi ikke bare en samling freelancere. Vi er et sammentømret
        hold af eksperter, der hver især brænder for vores felt.
      </p>

      <div class="hero-stats">
        <div class="stat">
          <strong class="stat-val" data-count={teamCount}>0</strong>
          <span class="stat-label">Specialister</span>
        </div>
        <span class="stat-divider"></span>
        <div class="stat">
          <strong class="stat-val" data-count={teamDepartments}>0</strong>
          <span class="stat-label">Afdelinger</span>
        </div>
        <span class="stat-divider"></span>
        <div class="stat">
          <strong class="stat-val">1</strong>
          <span class="stat-label">Fælles mission</span>
        </div>
      </div>
    </section>

    <!-- ─── Filter ─── -->
    <div class="filter-bar" role="tablist" aria-label="Filtrér holdet">
      {
        categories.map((c, i) => (
          <button
            class:list={['filter-pill', { 'is-active': i === 0 }]}
            data-cat={c.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {c.label}
          </button>
        ))
      }
    </div>

    <!-- ─── Grid ─── -->
    <section class="team-wrap">
      <div class="team-grid">
        {
          team.map((m) => {
            const src = photoFor(m.img);
            return (
              <article class="team-card" data-cat={m.cat}>
                <div class="card-photo">
                  {src && (
                    <Image src={src} alt={m.name} width={440} height={440} />
                  )}
                  <span class="card-cat">{catLabel[m.cat]}</span>
                </div>
                <div class="card-meta">
                  <h3>{m.name}</h3>
                  <p>{m.title}</p>
                </div>
              </article>
            );
          })
        }
      </div>

      <p class="no-results" hidden>Ingen i denne afdeling endnu.</p>
    </section>

    <!-- ─── CTA ─── -->
    <section class="team-cta">
      <h2>Vil du være en del af holdet?</h2>
      <p>Vi leder altid efter dygtige folk, der brænder for digital vækst.</p>
      <a href="#" class="cta-btn">Se ledige stillinger <i class="fa-solid fa-arrow-right"></i></a>
    </section>
  </main>
</Layout>

<style>
  main {
    background: #ffffff;
  }

  /* ─── Hero ─── */
  .team-hero {
    position: relative;
    text-align: center;
    padding: clamp(120px, 16vh, 180px) 24px 56px;
    max-width: 820px;
    margin: 0 auto;
    overflow: hidden;
  }

  .team-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 620px;
    max-width: 120vw;
    height: 420px;
    background: radial-gradient(circle, rgba(240, 90, 36, 0.12), transparent 68%);
    pointer-events: none;
    z-index: -1;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: #f05a24;
    margin-bottom: 22px;
    padding: 7px 18px;
    border: 1.5px solid #f9ddd2;
    border-radius: 999px;
    background: #fff7f3;
  }

  .hero-title {
    font-size: clamp(2.1rem, 5.5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.12;
    color: #1a1a1a;
    letter-spacing: 0.01em;
  }

  .hero-intro {
    margin: 22px auto 0;
    max-width: 540px;
    font-size: 1rem;
    line-height: 1.8;
    color: #777;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(20px, 5vw, 48px);
    margin-top: 44px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .stat-val {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #f05a24;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #999;
    font-weight: 600;
  }

  .stat-divider {
    width: 1px;
    height: 38px;
    background: #eee;
  }

  /* ─── Filter ─── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding: 8px 24px 0;
    max-width: 920px;
    margin: 0 auto 40px;
  }

  .filter-pill {
    font-family: 'Comfortaa', cursive;
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
    background: #f4f4f4;
    border: 1.5px solid transparent;
    padding: 9px 18px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }

  .filter-pill:hover {
    color: #f05a24;
    background: #fff3ee;
  }

  .filter-pill.is-active {
    background: #f05a24;
    color: #fff;
    border-color: #f05a24;
  }

  .filter-pill:active {
    transform: scale(0.96);
  }

  /* ─── Grid ─── */
  .team-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 120px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px;
  }

  .team-card {
    position: relative;
    background: #fbfbfb;
    border: 1px solid #efefef;
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.32s ease, box-shadow 0.32s ease, border-color 0.32s ease;
    will-change: transform;
  }

  .team-card::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 4px;
    width: 100%;
    background: #f05a24;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 60px rgba(240, 90, 36, 0.16);
    border-color: #f9ddd2;
  }

  .team-card:hover::after {
    transform: scaleX(1);
  }

  .card-photo {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f0f0f0;
  }

  .card-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.4s ease;
  }

  .team-card:hover .card-photo :global(img) {
    transform: scale(1.07);
  }

  .card-cat {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: #f05a24;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 5px 11px;
    border-radius: 999px;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .team-card:hover .card-cat {
    opacity: 1;
    transform: translateY(0);
  }

  .card-meta {
    padding: 18px 18px 22px;
  }

  .card-meta h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
    transition: color 0.25s ease;
  }

  .team-card:hover .card-meta h3 {
    color: #f05a24;
  }

  .card-meta p {
    font-size: 0.78rem;
    color: #888;
    margin-top: 5px;
    line-height: 1.4;
  }

  .no-results {
    text-align: center;
    color: #999;
    font-size: 0.95rem;
    padding: 40px 0;
  }

  /* ─── CTA ─── */
  .team-cta {
    text-align: center;
    background: #f05a24;
    color: #fff;
    padding: 80px 24px 88px;
  }

  .team-cta h2 {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .team-cta p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    color: #f05a24;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    padding: 15px 30px;
    border-radius: 999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .cta-btn i {
    font-size: 0.8rem;
    transition: transform 0.2s ease;
  }

  .cta-btn:hover i {
    transform: translateX(4px);
  }

  /* ─── Mobil ─── */
  @media (max-width: 768px) {
    .team-hero {
      padding-top: 120px;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .card-meta {
      padding: 14px 14px 18px;
    }

    .card-meta h3 {
      font-size: 0.88rem;
    }

    .card-meta p {
      font-size: 0.72rem;
    }

    .filter-bar {
      gap: 8px;
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      padding-bottom: 6px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .filter-bar::-webkit-scrollbar {
      display: none;
    }

    .filter-pill {
      flex: 0 0 auto;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { Flip } from 'gsap/Flip';

  gsap.registerPlugin(ScrollTrigger, Flip);

  /* ── Hero entrance ── */
  gsap.from('.team-hero > *', {
    y: 28,
    opacity: 0,
    duration: 0.8,
    ease: 'power3.out',
    stagger: 0.1,
  });

  /* ── Tæller-animation ── */
  function runCounters() {
    document.querySelectorAll<HTMLElement>('.stat-val[data-count]').forEach((el) => {
      const target = Number(el.dataset.count || '0');
      const obj = { val: 0 };
      gsap.to(obj, {
        val: target,
        duration: 1.6,
        ease: 'power2.out',
        onUpdate: () => {
          el.textContent = Math.round(obj.val).toString();
        },
      });
    });
  }
  runCounters();

  /* ── Kort: scroll-reveal med stagger ── */
  const cards = gsap.utils.toArray<HTMLElement>('.team-card');
  gsap.set(cards, { opacity: 0, y: 34 });

  ScrollTrigger.create({
    trigger: '.team-grid',
    start: 'top 85%',
    once: true,
    onEnter: () =>
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power3.out',
        stagger: { each: 0.035, grid: 'auto', from: 'start' },
      }),
  });

  /* ── Filter med GSAP Flip ── */
  const pills = gsap.utils.toArray<HTMLElement>('.filter-pill');
  const noResults = document.querySelector<HTMLElement>('.no-results');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const cat = pill.dataset.cat || 'alle';

      pills.forEach((p) => {
        const active = p === pill;
        p.classList.toggle('is-active', active);
        p.setAttribute('aria-selected', String(active));
      });

      // Optag nuværende layout før vi ændrer det
      const state = Flip.getState(cards, { props: 'opacity' });

      let visible = 0;
      cards.forEach((card) => {
        const show = cat === 'alle' || card.dataset.cat === cat;
        card.style.display = show ? '' : 'none';
        // Sørg for at synlige kort altid er fuldt synlige (i tilfælde af at scroll-reveal ikke nåede dem)
        if (show) {
          gsap.set(card, { opacity: 1, y: 0 });
          visible++;
        }
      });

      if (noResults) noResults.hidden = visible > 0;

      Flip.from(state, {
        duration: 0.55,
        scale: true,
        ease: 'power2.inOut',
        stagger: 0.025,
        absolute: true,
        onEnter: (els) =>
          gsap.fromTo(
            els,
            { opacity: 0, scale: 0.85 },
            { opacity: 1, scale: 1, duration: 0.45, ease: 'power2.out' }
          ),
        onLeave: (els) =>
          gsap.to(els, { opacity: 0, scale: 0.85, duration: 0.3, ease: 'power2.in' }),
      });
    });
  });
</script>

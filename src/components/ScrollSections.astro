---
import leonardoSrc from '../assets/Siite_Leonardo-removebg-preview.png?url';
import salesSrc from '../assets/Siite-Sales.webp?url';
---

<section class="h-section">
  <div class="h-track">

    <!-- Panel 1: animerer ind automatisk -->
    <div class="h-panel">
      <div class="h-card orange-card">
        <div class="card-content">
          <span class="label">Web · Branding · Marketing</span>
          <h2>Digitale løsninger<br>der konverterer</h2>
          <p>Vi hjælper ambitiøse virksomheder med at vokse online – fra webdesign og branding til performance-marketing der skaber resultater.</p>
          <a href="#" class="cta cta-white">Se vores cases →</a>
        </div>
        <div class="card-image">
          <img src={leonardoSrc} alt="Siite maskot" />
        </div>
      </div>
    </div>

    <!-- Panel 2: horisontal scroll, orange med team-billede og counters -->
    <div class="h-panel">
      <div class="h-card orange-card-2">
        <div class="card-content-2">
          <span class="label label-2">Hvem er Siite?</span>
          <h2 class="h2-2">Mød holdet bag<br>resultaterne</h2>
          <div class="counters">
            <div class="counter-item">
              <strong class="counter-val" id="c1">0</strong>
              <span class="counter-label">Dedikerede eksperter</span>
              <p class="counter-desc">Vi er ikke freelancere, men et fasttømret team af specialister inden for kode, design og annoncering.</p>
            </div>
            <div class="counter-item">
              <strong class="counter-val" id="c2">0+</strong>
              <span class="counter-label">Tilfredse kunder</span>
              <p class="counter-desc">Vi har hjulpet danske virksomheder i alle størrelser – fra den lokale håndværker til landsdækkende brands.</p>
            </div>
            <div class="counter-item">
              <strong class="counter-val" id="c3">0</strong>
              <span class="counter-label">Stjerner på Trustindex</span>
              <p class="counter-desc">Vi lever af glade kunder. Gennemsigtighed og ærlighed er nøglen til vores mange topanmeldelser.</p>
            </div>
          </div>
        </div>
        <div class="card-photo">
          <img src={salesSrc} alt="Siite salgsteam" />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .h-section {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: #f8f8f8;
  }

  .h-track {
    display: flex;
    width: 200vw;
    height: 100%;
  }

  .h-panel {
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
  }

  /* ── Base kort ── */
  .h-card {
    display: flex;
    align-items: stretch;
    border-radius: 32px;
    overflow: hidden;
    max-width: 1200px;
    width: 100%;
    min-height: 520px;
  }

  /* ── Kort 1: Orange ── */
  .orange-card {
    background: #f05a24;
  }

  .orange-card .card-content {
    flex: 0 0 54%;
    padding: 72px 48px 72px 72px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-image {
    flex: 0 0 46%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .card-image img {
    width: 90%;
    max-height: 500px;
    object-fit: contain;
    object-position: bottom center;
    display: block;
  }

  /* ── Kort 2: Orange med team ── */
  .orange-card-2 {
    background: #f05a24;
  }

  .card-content-2 {
    flex: 0 0 55%;
    padding: 56px 40px 56px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .label-2 {
    color: rgba(255, 255, 255, 0.65);
  }

  .h2-2 {
    color: #fff;
    font-size: clamp(1.8rem, 2.8vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 28px;
    font-family: 'Comfortaa', cursive;
  }

  .counters {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .counter-item {
    display: grid;
    grid-template-columns: 118px 1fr;
    grid-template-rows: auto auto;
    column-gap: 20px;
    align-items: start;
  }

  .counter-val {
    grid-row: 1 / 3;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    font-family: 'Comfortaa', cursive;
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: center;
  }

  .counter-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    font-family: 'Comfortaa', cursive;
    align-self: end;
  }

  .counter-desc {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.55;
    font-family: 'Comfortaa', cursive;
    margin: 0;
    max-width: 280px;
  }

  /* Team-billede i højre side — vises helt, ingen beskæring */
  .card-photo {
    flex: 0 0 45%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 56px 40px 0;
  }

  .card-photo img {
    width: 100%;
    max-height: 380px;
    object-fit: contain;
    border-radius: 16px;
    display: block;
  }

  /* ── Delte label/text styles ── */
  .label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 20px;
    font-family: 'Comfortaa', cursive;
    color: rgba(255, 255, 255, 0.65);
  }

  .card-content h2 {
    font-size: clamp(2rem, 3.2vw, 3.25rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.12;
    margin-bottom: 20px;
    font-family: 'Comfortaa', cursive;
  }

  .card-content p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.85;
    max-width: 420px;
    margin-bottom: 36px;
    font-family: 'Comfortaa', cursive;
  }

  .cta {
    align-self: flex-start;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-bottom: 2px solid;
    padding-bottom: 3px;
    transition: border-color 0.2s ease;
    font-family: 'Comfortaa', cursive;
  }

  .cta-white {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.45);
  }

  .cta-white:hover {
    border-bottom-color: #fff;
  }

  @media (max-width: 900px) {
    .h-panel {
      padding: 0 16px;
    }

    .h-card {
      flex-direction: column;
      min-height: auto;
    }

    .orange-card .card-content,
    .card-content-2 {
      flex: none;
      padding: 40px 24px 24px;
    }

    .card-image {
      flex: none;
      height: 220px;
    }

    .card-photo {
      flex: none;
      padding: 0 24px 32px;
    }

    .counter-val {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Fase 1: Orange kort animerer ind af sig selv
  gsap.from(".orange-card", {
    x: "100vw",
    opacity: 0,
    duration: 1.0,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".h-section",
      start: "top 70%",
      once: true,
    },
  });

  // Counter-animation (kører én gang når det andet kort er synligt)
  let countersStarted = false;

  function runCounters() {
    // Counter 1: 30
    const c1 = document.getElementById("c1")!;
    const obj1 = { val: 0 };
    gsap.to(obj1, {
      val: 30, duration: 1.8, ease: "power2.out",
      onUpdate: () => { c1.textContent = Math.round(obj1.val).toString(); },
    });

    // Counter 2: 800+
    const c2 = document.getElementById("c2")!;
    const obj2 = { val: 0 };
    gsap.to(obj2, {
      val: 800, duration: 2.2, ease: "power2.out",
      onUpdate: () => { c2.textContent = Math.round(obj2.val) + "+"; },
    });

    // Counter 3: 4.9
    const c3 = document.getElementById("c3")!;
    const obj3 = { val: 0 };
    gsap.to(obj3, {
      val: 4.9, duration: 1.6, ease: "power2.out",
      onUpdate: () => { c3.textContent = obj3.val.toFixed(1); },
    });
  }

  // Fase 2: Pin + horisontal scroll
  const hTl = gsap.timeline({
    scrollTrigger: {
      trigger: ".h-section",
      pin: true,
      anticipatePin: 1,
      start: "top top",
      end: "+=200%",
      scrub: 1,
      invalidateOnRefresh: true,
      onUpdate(self) {
        if (!countersStarted && self.progress >= 0.6) {
          countersStarted = true;
          runCounters();
        }
      },
    },
  });

  hTl
    .to(".h-track", { xPercent: -50, ease: "none", duration: 1 })
    .to({}, { duration: 0.35 }); // hold så panel 2 bliver i centrum til sidst
</script>

---
---

<section class="services-section">
  <div class="services-inner">
    <header class="services-head">
      <span class="services-eyebrow">Vores ydelser</span>
      <h2 class="services-title">En stærk digital motor,<br>der sikrer din vækst</h2>
    </header>

    <div class="services-grid">
      <article class="service-card has-preview" data-preview="web">
        <div class="service-body">
          <span class="service-icon"><i class="fa-solid fa-laptop-code"></i></span>
          <h3>Webudvikling &amp; Webshop</h3>
          <p>Det hele starter med fundamentet. Vi bygger brugervenlige hjemmesider og webshops, der er designet til at sælge, og som virker perfekt på mobilen.</p>
        </div>

        <div class="service-preview preview-web" aria-hidden="true">
          <div class="phone">
            <div class="phone-bar">
              <span class="phone-time">9:41</span>
              <span class="phone-status"><i class="fa-solid fa-signal"></i><i class="fa-solid fa-wifi"></i><i class="fa-solid fa-battery-three-quarters"></i></span>
            </div>
            <div class="phone-screen">
              <div class="notif">
                <span class="notif-ic ic-mail"><i class="fa-solid fa-envelope"></i></span>
                <span class="notif-text"><strong>Ny forespørgsel</strong><span>En kunde vil høre mere</span></span>
                <span class="notif-time">nu</span>
              </div>
              <div class="notif">
                <span class="notif-ic ic-cart"><i class="fa-solid fa-bag-shopping"></i></span>
                <span class="notif-text"><strong>Ny ordre</strong><span>1.499 kr · betalt</span></span>
                <span class="notif-time">nu</span>
              </div>
              <div class="notif">
                <span class="notif-ic ic-mail"><i class="fa-solid fa-envelope"></i></span>
                <span class="notif-text"><strong>Ny forespørgsel</strong><span>Tilbud ønskes</span></span>
                <span class="notif-time">nu</span>
              </div>
              <div class="notif">
                <span class="notif-ic ic-cart"><i class="fa-solid fa-bag-shopping"></i></span>
                <span class="notif-text"><strong>Ny ordre</strong><span>2.250 kr · betalt</span></span>
                <span class="notif-time">nu</span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <article class="service-card has-preview" data-preview="search">
        <div class="service-body">
          <span class="service-icon"><i class="fa-solid fa-chart-line"></i></span>
          <h3>Digital Marketing</h3>
          <p>Bliv fundet, når kunderne søger. Vi arbejder datadrevet med Google Ads, SEO og sociale medier for at skaffe dig flere henvendelser for færre kroner.</p>
        </div>

        <div class="service-preview preview-search" aria-hidden="true">
          <div class="search-ui">
            <div class="search-bar">
              <i class="fa-solid fa-magnifying-glass"></i>
              <span class="search-q" data-text="Tømrer Aalborg"></span>
              <span class="search-caret"></span>
            </div>
            <div class="search-results">
              <div class="sresult sr-comp">
                <span class="sr-fav"><i class="fa-solid fa-globe"></i></span>
                <span class="sr-text"><strong>Aalborg Tømrermester</strong><span>aalborg-toemrer.dk</span></span>
              </div>
              <div class="sresult sr-comp">
                <span class="sr-fav"><i class="fa-solid fa-globe"></i></span>
                <span class="sr-text"><strong>Nord Tømrer &amp; Snedker</strong><span>nordtoemrer.dk</span></span>
              </div>
              <div class="sresult sr-comp">
                <span class="sr-fav"><i class="fa-solid fa-globe"></i></span>
                <span class="sr-text"><strong>Aalborg Byg ApS</strong><span>aalborgbyg.dk</span></span>
              </div>
              <div class="sresult sr-you">
                <span class="sr-rank">#4</span>
                <span class="sr-text"><strong>Din Tømrervirksomhed</strong><span>dintoemrer.dk</span></span>
                <span class="sr-up"><i class="fa-solid fa-arrow-up"></i></span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <article class="service-card has-preview" data-preview="mail">
        <div class="service-body">
          <span class="service-icon"><i class="fa-solid fa-shield-halved"></i></span>
          <h3>Hosting &amp; Sikkerhed</h3>
          <p>Slip for teknisk bøvl. Vi sørger for lynhurtig hosting, daglig backup og mailopsætning, så din forretning altid er åben og sikret mod nedbrud.</p>
        </div>

        <div class="service-preview preview-mail" aria-hidden="true">
          <div class="ms-window">
            <div class="ms-step ms-signin">
              <div class="ms-logo">
                <span class="ms-grid"><i></i><i></i><i></i><i></i></span>
                Microsoft
              </div>
              <h4 class="ms-title">Log ind</h4>
              <div class="ms-field">
                <span class="ms-email" data-text="kontakt@dintoemrer.dk"></span>
                <span class="ms-caret"></span>
              </div>
              <span class="ms-hint">Din nye virksomhedsmail</span>
              <span class="ms-btn">Næste</span>
            </div>
            <div class="ms-step ms-success">
              <span class="ms-check"><i class="fa-solid fa-check"></i></span>
              <h4 class="ms-title">Postkassen er klar</h4>
              <div class="ms-mailrow">
                <span class="ms-mailic"><i class="fa-solid fa-envelope"></i></span>
                <span class="ms-mailaddr">kontakt@dintoemrer.dk</span>
              </div>
              <span class="ms-tag"><i class="fa-solid fa-shield-halved"></i> Sikret &amp; hostet</span>
            </div>
          </div>
        </div>
      </article>

      <article class="service-card has-preview" data-preview="content">
        <div class="service-body">
          <span class="service-icon"><i class="fa-solid fa-camera-retro"></i></span>
          <h3>Content &amp; Visuel Identitet</h3>
          <p>Tillid skabes gennem øjnene. Vi producerer professionelle billeder, video og grafisk design, der får din virksomhed til at fremstå knivskarpt.</p>
        </div>

        <div class="service-preview preview-content" aria-hidden="true">
          <div class="cta-stack">
            <a href="/kontakt" class="cta-tile">
              <span class="cta-ic"><i class="fa-solid fa-camera-retro"></i></span>
              <span class="cta-label"><strong>Foto &amp; Video</strong><span>Professionel produktion</span></span>
              <i class="fa-solid fa-arrow-right cta-arrow"></i>
            </a>
            <a href="/kontakt" class="cta-tile cta-tile-feature">
              <span class="cta-ic"><i class="fa-solid fa-infinity"></i></span>
              <span class="cta-label"><strong>Siite Unlimited</strong><span>Alt content — fast pris</span></span>
              <i class="fa-solid fa-arrow-right cta-arrow"></i>
            </a>
            <a href="/kontakt" class="cta-tile">
              <span class="cta-ic"><i class="fa-solid fa-pen-nib"></i></span>
              <span class="cta-label"><strong>Grafisk Design &amp; Identitet</strong><span>Logo, brand &amp; guidelines</span></span>
              <i class="fa-solid fa-arrow-right cta-arrow"></i>
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .services-section {
    background: #f8f8f8;
    padding: 130px clamp(20px, 4vw, 48px) 140px;
    position: relative;
    overflow: hidden;
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .services-head {
    text-align: center;
    margin-bottom: 68px;
  }

  .services-eyebrow {
    display: inline-block;
    font-family: 'Comfortaa', cursive;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: #f05a24;
    margin-bottom: 22px;
    padding: 7px 18px;
    border: 1.5px solid #f9ddd2;
    border-radius: 999px;
    background: #fff7f3;
  }

  .services-title {
    font-family: 'Comfortaa', cursive;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 700;
    line-height: 1.14;
    color: #1a1a1a;
    letter-spacing: 0.01em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #efefef;
    border-radius: 24px;
    padding: 40px 30px 36px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 4px;
    width: 100%;
    background: #f05a24;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 60px rgba(240, 90, 36, 0.13);
    border-color: #f9ddd2;
  }

  .service-card:hover::after {
    transform: scaleX(1);
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 62px;
    height: 62px;
    border-radius: 16px;
    background: #fff3ee;
    color: #f05a24;
    font-size: 1.5rem;
    margin-bottom: 26px;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }

  .service-card:hover .service-icon {
    background: #f05a24;
    color: #fff;
    transform: rotate(-6deg);
  }

  .service-card h3 {
    font-family: 'Comfortaa', cursive;
    font-size: 1.12rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
    margin-bottom: 14px;
    min-height: 2.6em; /* 2 linjer, så brødtekst flugter på tværs af kort */
  }

  .service-card p {
    font-family: 'Comfortaa', cursive;
    font-size: 0.85rem;
    line-height: 1.78;
    color: #6b6b6b;
  }

  .service-body {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* ── Hover-preview ("modal") ── */
  .service-preview {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: #ffffff;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.96);
    transition: opacity 0.3s ease, transform 0.35s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .has-preview:hover .service-body {
    opacity: 0;
    transform: translateY(-6px);
  }

  .has-preview:hover .service-preview {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  /* ── Telefon (Webudvikling) ── */
  .phone {
    width: 168px;
    background: #11141a;
    border-radius: 26px;
    padding: 8px 8px 12px;
    box-shadow: 0 18px 40px rgba(17, 20, 26, 0.28);
  }

  .phone-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2px 12px 8px;
    color: #fff;
    font-size: 0.52rem;
  }

  .phone-time {
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .phone-status {
    display: flex;
    gap: 4px;
    font-size: 0.5rem;
    opacity: 0.85;
  }

  .phone-screen {
    background: linear-gradient(160deg, #2a2f3a 0%, #1b1f27 100%);
    border-radius: 18px;
    padding: 12px 9px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 178px;
  }

  .notif {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 12px;
    padding: 8px 9px;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
    will-change: transform, opacity;
  }

  .notif-ic {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.62rem;
  }

  .ic-mail { background: #3b82f6; }
  .ic-cart { background: #f05a24; }

  .notif-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    min-width: 0;
  }

  .notif-text strong {
    font-size: 0.6rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .notif-text span {
    font-size: 0.54rem;
    color: #8a8f99;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .notif-time {
    margin-left: auto;
    font-size: 0.5rem;
    color: #b3b8c2;
    align-self: flex-start;
  }

  /* ── Google-søgning (Digital Marketing) ── */
  .search-ui {
    width: 100%;
    max-width: 252px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 16px 38px rgba(17, 20, 26, 0.16);
    border: 1px solid #eee;
    overflow: hidden;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    border-bottom: 1px solid #eee;
    color: #5f6368;
    font-size: 0.62rem;
  }

  .search-bar > .fa-magnifying-glass {
    font-size: 0.62rem;
    color: #f05a24;
  }

  .search-q {
    font-size: 0.72rem;
    font-weight: 600;
    color: #202124;
    white-space: nowrap;
    overflow: hidden;
  }

  .search-caret {
    width: 1.5px;
    height: 0.85rem;
    background: #f05a24;
    margin-left: -4px;
    animation: caret-blink 0.7s step-end infinite;
  }

  @keyframes caret-blink {
    50% { opacity: 0; }
  }

  .search-results {
    --row: 46px;
    position: relative;
    padding: 6px;
  }

  .sresult {
    display: flex;
    align-items: center;
    gap: 9px;
    height: var(--row);
    padding: 0 8px;
    border-radius: 10px;
    will-change: transform;
  }

  .sr-fav {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #f1f3f4;
    color: #9aa0a6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    flex-shrink: 0;
  }

  .sr-rank {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #eef0f2;
    color: #9aa0a6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.54rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .sr-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }

  .sr-text strong {
    font-size: 0.62rem;
    font-weight: 700;
    color: #1a0dab;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sr-text span {
    font-size: 0.52rem;
    color: #5f8c4e;
  }

  .sr-up {
    margin-left: auto;
    color: #34a853;
    font-size: 0.6rem;
    opacity: 0;
    flex-shrink: 0;
  }

  .sr-you {
    background: #fff7f3;
    box-shadow: inset 0 0 0 1.5px #fbcdb8;
  }

  .sr-you.is-first .sr-rank {
    background: #f05a24;
    color: #fff;
  }

  /* ── Microsoft-login (Hosting & Sikkerhed) ── */
  .ms-window {
    position: relative;
    width: 196px;
    min-height: 212px;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 16px 40px rgba(17, 20, 26, 0.18);
    border: 1px solid #eee;
    overflow: hidden;
  }

  .ms-step {
    position: absolute;
    inset: 0;
    padding: 20px 20px 18px;
    display: flex;
    flex-direction: column;
  }

  .ms-logo {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.62rem;
    font-weight: 700;
    color: #5e5e5e;
    margin-bottom: 16px;
  }

  .ms-grid {
    display: grid;
    grid-template-columns: 8px 8px;
    grid-template-rows: 8px 8px;
    gap: 2px;
  }

  .ms-grid i:nth-child(1) { background: #f25022; }
  .ms-grid i:nth-child(2) { background: #7fba00; }
  .ms-grid i:nth-child(3) { background: #00a4ef; }
  .ms-grid i:nth-child(4) { background: #ffb900; }

  .ms-title {
    font-family: 'Comfortaa', cursive;
    font-size: 0.84rem;
    font-weight: 700;
    color: #1b1b1b;
    margin-bottom: 14px;
  }

  .ms-field {
    display: flex;
    align-items: center;
    border-bottom: 1.5px solid #1b1b1b;
    padding-bottom: 7px;
    margin-bottom: 8px;
    min-height: 18px;
  }

  .ms-email {
    font-size: 0.66rem;
    color: #1b1b1b;
    white-space: nowrap;
    overflow: hidden;
  }

  .ms-caret {
    width: 1.5px;
    height: 0.8rem;
    background: #1b1b1b;
    margin-left: 1px;
    animation: caret-blink 0.7s step-end infinite;
  }

  .ms-hint {
    font-size: 0.54rem;
    color: #9aa0a6;
    margin-bottom: auto;
  }

  .ms-btn {
    align-self: flex-end;
    background: #0067b8;
    color: #fff;
    font-size: 0.62rem;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 3px;
  }

  /* Success-trin */
  .ms-success {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 4px;
  }

  .ms-check {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #e7f6ec;
    color: #2e9e5b;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    margin-bottom: 10px;
  }

  .ms-success .ms-title {
    margin-bottom: 12px;
  }

  .ms-mailrow {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #f4f7fb;
    border: 1px solid #e4ebf3;
    border-radius: 9px;
    padding: 7px 11px;
    margin-bottom: 12px;
    max-width: 100%;
  }

  .ms-mailic {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: #0067b8;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.56rem;
    flex-shrink: 0;
  }

  .ms-mailaddr {
    font-size: 0.6rem;
    font-weight: 700;
    color: #1b1b1b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ms-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.54rem;
    font-weight: 700;
    color: #f05a24;
    background: #fff3ee;
    padding: 5px 11px;
    border-radius: 999px;
  }

  /* ── CTA-stak (Content & Visuel Identitet) ── */
  .cta-stack {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    max-width: 268px;
  }

  .cta-tile {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 11px 13px;
    border-radius: 14px;
    background: #fff;
    border: 1px solid #ececec;
    box-shadow: 0 6px 16px rgba(17, 20, 26, 0.06);
    text-decoration: none;
    pointer-events: auto;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .cta-tile:hover {
    transform: translateX(3px);
    box-shadow: 0 10px 22px rgba(17, 20, 26, 0.1);
    border-color: #f9ddd2;
  }

  .cta-ic {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    border-radius: 10px;
    background: #fff3ee;
    color: #f05a24;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
  }

  .cta-label {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }

  .cta-label strong {
    font-size: 0.7rem;
    font-weight: 700;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cta-label span {
    font-size: 0.56rem;
    color: #8a8f99;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cta-arrow {
    margin-left: auto;
    font-size: 0.62rem;
    color: #c8ccd2;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .cta-tile:hover .cta-arrow {
    color: #f05a24;
    transform: translateX(2px);
  }

  /* Fremhævet tile: Siite Unlimited */
  .cta-tile-feature {
    background: #f05a24;
    border-color: #f05a24;
    box-shadow: 0 10px 24px rgba(240, 90, 36, 0.32);
  }

  .cta-tile-feature .cta-ic {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
  }

  .cta-tile-feature .cta-label strong { color: #fff; }
  .cta-tile-feature .cta-label span { color: rgba(255, 255, 255, 0.8); }
  .cta-tile-feature .cta-arrow { color: rgba(255, 255, 255, 0.85); }

  .cta-tile-feature:hover {
    border-color: #fff;
  }

  .cta-tile-feature:hover .cta-arrow {
    color: #fff;
  }

  @media (max-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .services-section {
      padding: 90px clamp(20px, 4vw, 48px) 96px;
    }

    .services-head {
      margin-bottom: 44px;
    }
  }

  @media (max-width: 560px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }

  /* Touch-enheder: ingen hover, så vis animationen inline under teksten */
  @media (hover: none) {
    .has-preview .service-body {
      opacity: 1 !important;
      transform: none !important;
    }

    .has-preview .service-preview {
      position: static;
      inset: auto;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
      background: transparent;
      padding: 24px 0 4px;
      margin-top: 24px;
      min-height: 0;
      border-top: 1px solid #efefef;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initServices() {
    const section = document.querySelector(".services-section");
    if (!section) return; // Findes kun på forsiden
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.from(".services-head > *", {
      y: 28,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
      stagger: 0.12,
      scrollTrigger: { trigger: ".services-head", start: "top 82%", once: true },
    });

    gsap.from(".service-card", {
      y: 48,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
      stagger: 0.12,
      scrollTrigger: { trigger: ".services-grid", start: "top 80%", once: true },
    });
  }

  // ── Hover-previews: telefon-notifikationer + Google-ranking ──
  function buildPhoneTimeline(card: Element) {
    const notifs = card.querySelectorAll(".notif");
    const tl = gsap.timeline({ repeat: -1, repeatDelay: 0.8, paused: true });
    tl.set(notifs, { opacity: 0, y: -16, scale: 0.96 });
    notifs.forEach((n, i) => {
      tl.to(n, { opacity: 1, y: 0, scale: 1, duration: 0.45, ease: "back.out(1.7)" }, 0.55 * i + 0.2);
    });
    tl.to(notifs, { opacity: 0, y: 12, duration: 0.4, ease: "power2.in", stagger: 0.06 }, "+=0.9");
    return tl;
  }

  function buildSearchTimeline(card: Element) {
    const ROW = 46;
    const q = card.querySelector(".search-q") as HTMLElement;
    const comps = card.querySelectorAll(".sr-comp");
    const you = card.querySelector(".sr-you") as HTMLElement;
    const rank = card.querySelector(".sr-rank") as HTMLElement;
    const up = card.querySelector(".sr-up") as HTMLElement;
    const full = q.dataset.text ?? "";
    q.textContent = full;

    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.4, paused: true });
    tl.call(() => {
      rank.textContent = "#4";
      you.classList.remove("is-first");
    });
    tl.set(up, { opacity: 0 });
    tl.fromTo(q, { width: 0 }, { width: () => q.scrollWidth + 2, duration: 1.0, ease: `steps(${full.length})` });
    tl.fromTo(comps, { y: 0 }, { y: ROW, duration: 0.7, ease: "power2.inOut" }, "move+=0.5");
    tl.fromTo(you, { y: 0 }, { y: -3 * ROW, duration: 0.7, ease: "power2.inOut" }, "move+=0.5");
    tl.call(() => { rank.textContent = "#1"; you.classList.add("is-first"); }, undefined, "move+=0.95");
    tl.to(up, { opacity: 1, duration: 0.3, ease: "power2.out" }, "move+=0.95");
    tl.to({}, { duration: 0.6 });
    return tl;
  }

  function buildMailTimeline(card: Element) {
    const email = card.querySelector(".ms-email") as HTMLElement;
    const caret = card.querySelector(".ms-caret") as HTMLElement;
    const btn = card.querySelector(".ms-btn") as HTMLElement;
    const step1 = card.querySelector(".ms-signin") as HTMLElement;
    const step2 = card.querySelector(".ms-success") as HTMLElement;
    const check = card.querySelector(".ms-check") as HTMLElement;
    const tag = card.querySelector(".ms-tag") as HTMLElement;
    const full = email.dataset.text ?? "";
    email.textContent = full;

    const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.2, paused: true });
    tl.set(step1, { opacity: 1, y: 0 });
    tl.set(step2, { opacity: 0, y: 16 });
    tl.set(check, { scale: 0 });
    tl.set(tag, { opacity: 0, y: 8 });
    tl.set(caret, { opacity: 1 });
    tl.fromTo(email, { width: 0 }, { width: () => email.scrollWidth + 2, duration: 1.0, ease: `steps(${full.length})` }, 0.2);
    tl.to(btn, { scale: 1.06, duration: 0.16, yoyo: true, repeat: 1, transformOrigin: "right center" }, "+=0.35");
    tl.to(caret, { opacity: 0, duration: 0.1 });
    tl.to(step1, { opacity: 0, y: -16, duration: 0.4, ease: "power2.in" }, "+=0.05");
    tl.to(step2, { opacity: 1, y: 0, duration: 0.45, ease: "power2.out" }, "<0.12");
    tl.to(check, { scale: 1, duration: 0.45, ease: "back.out(2.2)" }, "<0.1");
    tl.to(tag, { opacity: 1, y: 0, duration: 0.35, ease: "power2.out" }, ">-0.1");
    tl.to({}, { duration: 1.0 });
    return tl;
  }

  function buildContentTimeline(card: Element) {
    const tiles = card.querySelectorAll(".cta-tile");
    const tl = gsap.timeline({ paused: true });
    tl.set(tiles, { opacity: 0, x: 26 });
    tl.to(tiles, { opacity: 1, x: 0, duration: 0.5, ease: "back.out(1.5)", stagger: 0.12 });
    return tl;
  }

  function showContentStatic(card: Element) {
    gsap.set(card.querySelectorAll(".cta-tile"), { opacity: 1, x: 0 });
  }

  function showMailStatic(card: Element) {
    const email = card.querySelector(".ms-email") as HTMLElement;
    const step1 = card.querySelector(".ms-signin") as HTMLElement;
    const step2 = card.querySelector(".ms-success") as HTMLElement;
    email.textContent = email.dataset.text ?? "";
    gsap.set(step1, { opacity: 0 });
    gsap.set(step2, { opacity: 1, y: 0 });
  }

  function showSearchStatic(card: Element) {
    const q = card.querySelector(".search-q") as HTMLElement;
    const you = card.querySelector(".sr-you") as HTMLElement;
    const rank = card.querySelector(".sr-rank") as HTMLElement;
    const up = card.querySelector(".sr-up") as HTMLElement;
    const comps = card.querySelectorAll(".sr-comp");
    q.textContent = q.dataset.text ?? "";
    gsap.set(comps, { y: 46 });
    gsap.set(you, { y: -3 * 46 });
    gsap.set(up, { opacity: 1 });
    rank.textContent = "#1";
    you.classList.add("is-first");
  }

  function initServicePreviews() {
    const cards = document.querySelectorAll<HTMLElement>(".service-card.has-preview");
    if (!cards.length) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    // Touch-enheder har ingen hover: vis previews inline og afspil ved scroll-into-view
    const touch = window.matchMedia("(hover: none)").matches;

    cards.forEach((card) => {
      const type = card.dataset.preview;

      if (reduce) {
        if (type === "search") showSearchStatic(card);
        if (type === "mail") showMailStatic(card);
        if (type === "content") showContentStatic(card);
        return; // statisk visning, ingen loop-animation
      }

      let tl: gsap.core.Timeline;
      if (type === "web") tl = buildPhoneTimeline(card);
      else if (type === "search") tl = buildSearchTimeline(card);
      else if (type === "mail") tl = buildMailTimeline(card);
      else tl = buildContentTimeline(card);

      if (touch) {
        // Afspil når kortet er i billedet, pause når det forlader (sparer CPU/batteri)
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) tl.play();
              else tl.pause();
            });
          },
          { threshold: 0.35 }
        );
        io.observe(card);
        document.addEventListener("astro:before-swap", () => io.disconnect(), { once: true });
        return;
      }

      const enter = () => tl.restart();
      const leave = () => tl.pause(0);
      card.addEventListener("mouseenter", enter);
      card.addEventListener("focusin", enter);
      card.addEventListener("mouseleave", leave);
      card.addEventListener("focusout", leave);
    });
  }

  document.addEventListener("astro:page-load", () => {
    initServices();
    initServicePreviews();
  });
</script>
